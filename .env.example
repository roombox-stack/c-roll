# Supabase — https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Mux — https://dashboard.mux.com/settings/access-tokens
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
MUX_WEBHOOK_SECRET=

# Cloudflare R2 — https://dash.cloudflare.com/?to=/:account/r2/overview
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=showside-media
R2_PUBLIC_URL=

# Admin — any long random string
ADMIN_KEY=

# App
# Local dev uses localhost; production should be set to https://c-roll.app
NEXT_PUBLIC_APP_URL=http://localhost:3000
